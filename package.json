{
  "name": "interviewprepchatbot",
  "version": "1.0.0",
  "description": "Backend project for an interview preparation chatbot using Node.js, Express, and SQLite.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node src/data/seedInterviewData.js",
    "seed:mock": "node src/data/seedMockInterviewQuestions.js",
    "seed:technical": "node src/data/seedTechnicalInterviewQuestions.js",
    "seed:synthetic": "node src/data/seedSyntheticInterviewQuestions.js",
    "client:dev": "npm --prefix client run dev",
    "client:build": "npm --prefix client run build"
  },
  "keywords": [
    "nodejs",
    "express",
    "sqlite",
    "chatbot",
    "interview-prep"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
